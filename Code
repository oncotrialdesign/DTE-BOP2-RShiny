rinvgamma <- function(n, shape, rate = 1, scale = 1/rate) {
  1 / rgamma(n, shape = shape, rate = 1/scale)
}
dinvgamma <- function(x, shape, rate = 1, scale = 1/rate) {
  ifelse(x > 0,
    (1/scale)^shape / gamma(shape) * x^(-shape-1) * exp(-1/(x*scale)),
    0)
}
qinvgamma <- function(p, shape, rate = 1, scale = 1/rate) {
  1 / qgamma(1-p, shape=shape, rate=1/scale)
}

