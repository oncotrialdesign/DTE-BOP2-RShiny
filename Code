# ── SERVER ────────────────────────────────────────────────────────────────────
server <- function(input, output, session) {

  # Reactive values store
  rv <- reactiveValues(
    s1 = 12.86, s2 = 0.19,
    L  = 2,     U  = 4,
    lambda_opt = NULL, gamma_opt = NULL,
    oc_results = NULL,
    analysis_result = NULL
  )

  # ── PRIOR TAB ──────────────────────────────────────────────────────────────
  observeEvent(input$fit_prior, {
    req(input$L, input$U, input$L < input$U)

    # Use manual override if provided
    if (!is.na(input$s1_manual) && !is.na(input$s2_manual)) {
      rv$s1 <- input$s1_manual
      rv$s2 <- input$s2_manual
      rv$L  <- input$L
      rv$U  <- input$U
      showNotification("Prior updated using manual parameters.", type="message")
      return()
    }

    # Fit from elicitation
    withProgress(message="Fitting prior...", {
      res <- fit_prior_S(
        L = input$L, U = input$U,
        mean_val   = if(!is.na(input$mean_S))  input$mean_S  else NULL,
        median_val = if(!is.na(input$med_S))   input$med_S   else NULL,
        sd_val     = if(!is.na(input$sd_S))    input$sd_S    else NULL,
        q025       = if(!is.na(input$q025_S))  input$q025_S  else NULL,
        q975       = if(!is.na(input$q975_S))  input$q975_S  else NULL
      )
      rv$s1 <- res$s1; rv$s2 <- res$s2
      rv$L  <- input$L; rv$U  <- input$U

      if (!res$converged)
        showNotification("Optimiser did not fully converge — results are approximate.", type="warning")
      else
        showNotification(sprintf("Prior fitted: s₁=%.3f, s₂=%.4f", res$s1, res$s2), type="message")
    })
  })

  output$prior_s1_box <- renderValueBox({
    valueBox(round(rv$s1, 3), "Shape s₁", icon=icon("shapes"), color="blue")
  })
  output$prior_s2_box <- renderValueBox({
    valueBox(round(rv$s2, 4), "Scale s₂", icon=icon("ruler"), color="green")
  })
  output$prior_mean_box <- renderValueBox({
    samps <- tryCatch(rtrunc(5000,"gamma",a=rv$L,b=rv$U,shape=rv$s1,scale=rv$s2), error=function(e) NULL)
    m <- if (!is.null(samps)) round(mean(samps),3) else "—"
    valueBox(m, "Prior mean of S", icon=icon("calculator"), color="yellow")
  })

  output$prior_plot <- renderPlotly({
    samps <- tryCatch(rtrunc(10000,"gamma",a=rv$L,b=rv$U,shape=rv$s1,scale=rv$s2), error=function(e) NULL)
    if (is.null(samps)) return(NULL)
    df <- data.frame(S=samps)
    p <- ggplot(df, aes(x=S)) +
      geom_histogram(aes(y=after_stat(density)), bins=50,
                     fill="#3498db", alpha=0.7, color="white") +
      geom_density(color="#2c3e50", linewidth=1.2) +
      geom_vline(xintercept=rv$L, color="#e74c3c", linetype="dashed", linewidth=1) +
      geom_vline(xintercept=rv$U, color="#e74c3c", linetype="dashed", linewidth=1) +
      labs(x="Delay Timepoint S (months)", y="Density",
           title=sprintf("Truncated Gamma Prior: S ~ Gamma(%.2f, %.3f) I(%.1f, %.1f)",
                         rv$s1, rv$s2, rv$L, rv$U)) +
      theme_minimal(base_size=13) +
      theme(plot.title=element_text(size=11, face="bold"))
    ggplotly(p)
  })

  output$prior_summary_table <- renderTable({
    samps <- tryCatch(rtrunc(10000,"gamma",a=rv$L,b=rv$U,shape=rv$s1,scale=rv$s2), error=function(e) NULL)
    if (is.null(samps)) return(NULL)
    data.frame(
      Statistic = c("Mean","Median","Std Dev","2.5th pct","97.5th pct","Mode"),
      Value = round(c(mean(samps), median(samps), sd(samps),
                      quantile(samps,0.025), quantile(samps,0.975),
                      (rv$s1-1)*rv$s2), 3)
    )
  }, striped=TRUE, hover=TRUE, bordered=TRUE)

  output$prior_interpretation <- renderUI({
    samps <- tryCatch(rtrunc(5000,"gamma",a=rv$L,b=rv$U,shape=rv$s1,scale=rv$s2), error=function(e) NULL)
    if (is.null(samps)) return(NULL)
    tags$div(
      p(sprintf("The prior on S is bounded between %.1f and %.1f months.", rv$L, rv$U)),
      p(sprintf("The expected delay is %.2f months (median: %.2f months).", mean(samps), median(samps))),
      p(sprintf("There is 95%% prior probability that S lies between %.2f and %.2f months.",
                quantile(samps,0.025), quantile(samps,0.975))),
      p(style="color:#7f8c8d; font-size:11px;",
        sprintf("Parameters: s₁ = %.3f (shape), s₂ = %.4f (scale)", rv$s1, rv$s2))
    )
  })

  # ── SAMPLE SIZE TAB ────────────────────────────────────────────────────────
  output$interim_fraction_ui_ss <- renderUI({
    n <- input$n_interim_ss
    if (n == 0) return(NULL)
    fracs <- seq(0.5/n, 1 - 0.5/n, length.out=n)
    lapply(1:n, function(i) {
      numericInput(paste0("frac_ss_", i),
                   sprintf("Interim %d fraction of N", i),
                   value=round(fracs[i],2), min=0.1, max=0.95, step=0.05)
    })
  })

  observeEvent(input$calc_ss, {
    req(input$mu0_bar, input$mu1_bar, input$S_design)
    req(input$mu1_bar > input$mu0_bar)

    withProgress(message="Computing sample size...", {
      # Simulation-based sample size search
      mu0 <- input$mu0_bar; mu1 <- input$mu1_bar
      S   <- input$S_design
      al  <- input$alpha_ss; pw <- input$power_ss
      a0  <- input$a0_ss; b0 <- input$b0_ss
      a1  <- input$a1_ss; b1 <- input$b1_ss

      # Simple lambda/gamma defaults for SS calculation
      lam <- 0.5; gam <- 1.0
      n_sim_ss <- 500

      Ns <- seq(20, 200, by=10)
      powers <- numeric(length(Ns))
      t1es   <- numeric(length(Ns))

      for (j in seq_along(Ns)) {
        N <- Ns[j]
        n_int_frac <- input$n_interim_ss
        if (n_int_frac == 0) {
          n_int <- integer(0)
        } else {
          fracs <- sapply(1:n_int_frac, function(i) {
            v <- input[[paste0("frac_ss_", i)]]
            if (is.null(v)) 0.5 else v
          })
          n_int <- round(fracs * N)
        }

        rej_h0 <- replicate(n_sim_ss, {
          r <- simulate_one_trial(n_int, N, lam, gam,
                                  mu0, null=TRUE, S_val=S,
                                  a0=a0, b0=b0, a1=a1, b1=b1)
          as.numeric(r$reject)
        })
        t1es[j] <- mean(rej_h0)

        rej_h1 <- replicate(n_sim_ss, {
          r <- simulate_one_trial(n_int, N, lam, gam,
                                  mu0, mu1_bar=mu1, S_val=S, null=FALSE,
                                  a0=a0, b0=b0, a1=a1, b1=b1)
          as.numeric(r$reject)
        })
        powers[j] <- mean(rej_h1)
      }

      # Find smallest N achieving target power with type I <= alpha
      valid <- which(t1es <= al + 0.02)  # small tolerance
      if (length(valid) == 0) {
        rv$ss_result <- list(found=FALSE, N=NA, power=NA, t1e=NA,
                             Ns=Ns, powers=powers, t1es=t1es)
      } else {
        ok <- valid[powers[valid] >= pw]
        if (length(ok) == 0) ok <- valid[which.max(powers[valid])]
        idx <- min(ok)
        rv$ss_result <- list(found=TRUE, N=Ns[idx], power=powers[idx], t1e=t1es[idx],
                             Ns=Ns, powers=powers, t1es=t1es)
      }
    })
  })

  rv$ss_result <- NULL

  output$ss_results_ui <- renderUI({
    res <- rv$ss_result
    if (is.null(res)) {
      return(p(style="color:#95a5a6; font-style:italic;",
               "Set parameters and click 'Calculate Sample Size'."))
    }
    if (!res$found) {
      return(div(class="decision-box decision-stop",
                 "No valid sample size found in range. Adjust parameters."))
    }
    fluidRow(
      column(3, div(class="param-well", h4(class="result-label","Recommended N (per arm)"),
                    h2(style="color:#27ae60;font-weight:700;", res$N))),
      column(3, div(class="param-well", h4(class="result-label","Total 2N"),
                    h2(style="color:#2980b9;font-weight:700;", res$N*2))),
      column(3, div(class="param-well", h4(class="result-label","Estimated Power"),
                    h2(style="color:#8e44ad;font-weight:700;", sprintf("%.1f%%", res$power*100)))),
      column(3, div(class="param-well", h4(class="result-label","Type I Error"),
                    h2(style="color:#e67e22;font-weight:700;", sprintf("%.1f%%", res$t1e*100))))
    )
  })

  output$ss_power_curve <- renderPlotly({
    res <- rv$ss_result
    if (is.null(res)) return(NULL)
    df <- data.frame(N=res$Ns, Power=res$powers, T1E=res$t1es)
    p <- ggplot(df, aes(x=N*2)) +
      geom_line(aes(y=Power, color="Power"), linewidth=1.3) +
      geom_line(aes(y=T1E,   color="Type I Error"), linewidth=1.1, linetype="dashed") +
      geom_hline(yintercept=input$power_ss, color="#27ae60", linetype="dotted", linewidth=0.8) +
      geom_hline(yintercept=input$alpha_ss, color="#e74c3c", linetype="dotted", linewidth=0.8) +
      scale_color_manual(values=c("Power"="#3498db","Type I Error"="#e74c3c")) +
      labs(x="Total Sample Size (2N)", y="Probability", color="",
           title="Power and Type I Error vs. Sample Size") +
      theme_minimal(base_size=13) + ylim(0,1)
    ggplotly(p)
  })

  # ── CALIBRATION TAB ────────────────────────────────────────────────────────
  output$interim_sizes_ui <- renderUI({
    tagList(
      numericInput("n_interim_cal", "Number of interim analyses", value=1, min=0, max=4, step=1),
      uiOutput("interim_n_inputs_cal")
    )
  })

  output$interim_n_inputs_cal <- renderUI({
    n <- input$n_interim_cal
    if (is.null(n) || n == 0) return(NULL)
    N <- input$N_cal / 2
    lapply(1:n, function(i) {
      numericInput(paste0("n_int_cal_", i),
                   sprintf("Interim %d: sample size per arm", i),
                   value=round(N * i/(n+1)), min=5, step=5)
    })
  })

  observeEvent(input$run_calibration, {
    req(input$N_cal, input$mu0_cal, input$mu1_cal)

    withProgress(message="Running calibration...", {
      N   <- input$N_cal / 2
      n_i <- if (is.null(input$n_interim_cal) || input$n_interim_cal == 0) {
        integer(0)
      } else {
        sapply(1:input$n_interim_cal, function(i) {
          v <- input[[paste0("n_int_cal_", i)]]
          if (is.null(v)) round(N * i/(input$n_interim_cal+1)) else v
        })
      }

      lam_seq <- seq(input$lambda_range[1], input$lambda_range[2], by=0.1)
      gam_seq <- seq(input$gamma_range[1],  input$gamma_range[2],  by=0.25)

      grid_res <- list()
      total_iter <- length(lam_seq) * length(gam_seq)
      iter <- 0
      best_power <- -Inf; best_lam <- NA; best_gam <- NA
      best_t1e <- NA

      for (lam in lam_seq) {
        for (gam in gam_seq) {
          iter <- iter + 1
          setProgress(iter/total_iter,
                      detail=sprintf("λ=%.2f, γ=%.2f (%d/%d)", lam, gam, iter, total_iter))

          rej_h0 <- replicate(input$n_sim_cal, {
            S_s <- rtrunc(1,"gamma",a=input$L_cal,b=input$U_cal,
                          shape=input$s1_cal, scale=input$s2_cal)
            r <- simulate_one_trial(n_i, N, lam, gam,
                                    input$mu0_cal, null=TRUE, S_val=S_s,
                                    a0=input$a0_cal, b0=input$b0_cal,
                                    a1=input$a1_cal, b1=input$b1_cal)
            as.numeric(r$reject)
          })
          t1e <- mean(rej_h0)

          rej_h1 <- replicate(input$n_sim_cal, {
            S_s <- rtrunc(1,"gamma",a=input$L_cal,b=input$U_cal,
                          shape=input$s1_cal, scale=input$s2_cal)
            r <- simulate_one_trial(n_i, N, lam, gam,
                                    input$mu0_cal, mu1_bar=input$mu1_cal,
                                    S_val=S_s, null=FALSE,
                                    a0=input$a0_cal, b0=input$b0_cal,
                                    a1=input$a1_cal, b1=input$b1_cal)
            as.numeric(r$reject)
          })
          pwr <- mean(rej_h1)

          grid_res[[length(grid_res)+1]] <- list(lambda=lam, gamma=gam, t1e=t1e, power=pwr)

          if (t1e <= input$alpha_cal && pwr > best_power) {
            best_power <- pwr; best_lam <- lam; best_gam <- gam; best_t1e <- t1e
          }
        }
      }

      rv$lambda_opt <- best_lam
      rv$gamma_opt  <- best_gam
      rv$cal_grid   <- do.call(rbind, lapply(grid_res, as.data.frame))
      rv$cal_best   <- list(lambda=best_lam, gamma=best_gam,
                            power=best_power, t1e=best_t1e)

      # Update OC defaults
      updateNumericInput(session, "lambda_oc", value=round(best_lam, 3))
      updateNumericInput(session, "gamma_oc",  value=round(best_gam, 3))
      updateNumericInput(session, "lambda_an", value=round(best_lam, 3))
      updateNumericInput(session, "gamma_an",  value=round(best_gam, 3))
    })
  })

  output$cal_results_ui <- renderUI({
    b <- rv$cal_best
    if (is.null(b)) {
      return(p(style="color:#95a5a6; font-style:italic;",
               "Set parameters and click 'Run Calibration'."))
    }
    if (is.na(b$lambda)) {
      return(div(class="decision-box decision-stop",
                 "No valid (λ, γ) found controlling type I error. Try larger grid or n_sim."))
    }
    tagList(
      fluidRow(
        column(3, div(class="param-well",
                      h4(class="result-label","Optimal λ"),
                      h2(style="color:#e74c3c;font-weight:700;", round(b$lambda,3)))),
        column(3, div(class="param-well",
                      h4(class="result-label","Optimal γ"),
                      h2(style="color:#3498db;font-weight:700;", round(b$gamma,3)))),
        column(3, div(class="param-well",
                      h4(class="result-label","Power"),
                      h2(style="color:#27ae60;font-weight:700;", sprintf("%.1f%%", b$power*100)))),
        column(3, div(class="param-well",
                      h4(class="result-label","Type I Error"),
                      h2(style="color:#e67e22;font-weight:700;", sprintf("%.1f%%", b$t1e*100))))
      ),
      br(),
      p(sprintf("Threshold function: C(n) = 1 − %.3f × (n/N)^%.3f", b$lambda, b$gamma),
        style="font-family:monospace; font-size:14px;")
    )
  })

  output$cal_grid_plot <- renderPlotly({
    df <- rv$cal_grid
    if (is.null(df)) return(NULL)
    df$valid <- df$t1e <= input$alpha_cal
    p <- ggplot(df, aes(x=lambda, y=gamma, fill=power, alpha=valid)) +
      geom_tile() +
      geom_text(aes(label=sprintf("%.2f", power)), size=2.5, color="white") +
      scale_fill_gradient2(low="#e74c3c", mid="#f39c12", high="#27ae60",
                           midpoint=0.6, limits=c(0,1)) +
      scale_alpha_manual(values=c("FALSE"=0.2,"TRUE"=1)) +
      labs(x="λ", y="γ", fill="Power",
           title=sprintf("Power grid (shaded = type I error > %.2f)", input$alpha_cal)) +
      theme_minimal(base_size=12)
    ggplotly(p)
  })

  output$threshold_plot <- renderPlotly({
    b <- rv$cal_best
    if (is.null(b) || is.na(b$lambda)) return(NULL)
    N <- input$N_cal / 2
    n_seq <- seq(1, N, by=1)
    C_seq <- threshold_C(n_seq, N, b$lambda, b$gamma)
    df <- data.frame(n=n_seq*2, C=C_seq)
    p <- ggplot(df, aes(x=n, y=C)) +
      geom_line(color="#8e44ad", linewidth=1.5) +
      geom_hline(yintercept=0.5, linetype="dashed", color="#95a5a6") +
      labs(x="Current total sample size (2n)", y="C(n)",
           title=sprintf("Adaptive threshold: C(n) = 1 − %.3f·(n/N)^%.3f",
                         b$lambda, b$gamma)) +
      theme_minimal(base_size=12) + ylim(0,1)
    ggplotly(p)
  })

  # ── OC TAB ─────────────────────────────────────────────────────────────────
  output$interim_oc_ui <- renderUI({
    tagList(
      numericInput("n_interim_oc_n", "Number of interim looks", value=1, min=0, max=4, step=1),
      uiOutput("interim_oc_inputs")
    )
  })
  output$interim_oc_inputs <- renderUI({
    n <- input$n_interim_oc_n
    if (is.null(n) || n==0) return(NULL)
    N <- input$N_oc / 2
    lapply(1:n, function(i) {
      numericInput(paste0("n_oc_int_", i),
                   sprintf("Interim %d: n per arm", i),
                   value=round(N * i/(n+1)), min=5, step=5)
    })
  })

  observeEvent(input$run_oc, {
    req(input$N_oc, input$lambda_oc, input$gamma_oc)

    withProgress(message="Simulating operating characteristics...", {
      N   <- input$N_oc / 2
      n_i <- if (is.null(input$n_interim_oc_n) || input$n_interim_oc_n == 0) {
        integer(0)
      } else {
        sapply(1:input$n_interim_oc_n, function(i) {
          v <- input[[paste0("n_oc_int_", i)]]
          if (is.null(v)) round(N/2) else v
        })
      }

      use_prior <- input$S_spec_oc == "prior"
      S_fix     <- if (!use_prior) input$S_fixed_oc else NULL

      oc <- compute_oc(
        N_total  = N,
        n_interim = n_i,
        lambda   = input$lambda_oc,
        gamma    = input$gamma_oc,
        mu0_bar  = input$mu0_oc,
        mu1_bar  = input$mu1_oc,
        S_fixed  = S_fix,
        s1 = if (use_prior) input$s1_oc else NULL,
        s2 = if (use_prior) input$s2_oc else NULL,
        L  = if (use_prior) input$L_oc  else NULL,
        U  = if (use_prior) input$U_oc  else NULL,
        a0 = input$a0_oc, b0=input$b0_oc,
        a1 = input$a1_oc, b1=input$b1_oc,
        n_sim    = input$n_sim_oc,
        use_prior = use_prior
      )
      rv$oc_results <- oc

      # Sensitivity analysis
      if (input$run_sensitivity) {
        S_vals <- seq(input$S_range_oc[1], input$S_range_oc[2], by=0.5)
        sens <- lapply(S_vals, function(sv) {
          setProgress(detail=sprintf("S = %.1f", sv))
          oc_s <- compute_oc(N, n_i, input$lambda_oc, input$gamma_oc,
                             input$mu0_oc, input$mu1_oc,
                             S_fixed=sv, use_prior=FALSE,
                             a0=input$a0_oc, b0=input$b0_oc,
                             a1=input$a1_oc, b1=input$b1_oc,
                             n_sim=min(input$n_sim_oc, 500))
          list(S=sv, power=oc_s$power, t1e=oc_s$type1_error)
        })
        rv$oc_sensitivity <- do.call(rbind, lapply(sens, as.data.frame))
      }
    })
  })

  output$oc_results_ui <- renderUI({
    oc <- rv$oc_results
    if (is.null(oc)) {
      return(p(style="color:#95a5a6; font-style:italic;",
               "Set parameters and click 'Compute Operating Characteristics'."))
    }
    fluidRow(
      column(2, div(class="param-well",
                    h4(class="result-label","Type I Error"),
                    h3(style="color:#e74c3c;font-weight:700;", sprintf("%.3f", oc$type1_error)))),
      column(2, div(class="param-well",
                    h4(class="result-label","Power"),
                    h3(style="color:#27ae60;font-weight:700;", sprintf("%.3f", oc$power)))),
      column(2, div(class="param-well",
                    h4(class="result-label","PES (H₀)"),
                    h3(style="color:#8e44ad;font-weight:700;", sprintf("%.3f", oc$pes_h0)))),
      column(2, div(class="param-well",
                    h4(class="result-label","PES (H₁)"),
                    h3(style="color:#3498db;font-weight:700;", sprintf("%.3f", oc$pes_h1)))),
      column(2, div(class="param-well",
                    h4(class="result-label","Avg N (H₀)"),
                    h3(style="color:#e67e22;font-weight:700;", sprintf("%.0f", oc$avg_n_h0)))),
      column(2, div(class="param-well",
                    h4(class="result-label","Avg N (H₁)"),
                    h3(style="color:#1abc9c;font-weight:700;", sprintf("%.0f", oc$avg_n_h1))))
    )
  })

  output$oc_bar_plot <- renderPlotly({
    oc <- rv$oc_results
    if (is.null(oc)) return(NULL)
    df <- data.frame(
      Metric = c("Type I Error","Power","PES (H₀)","PES (H₁)"),
      Value  = c(oc$type1_error, oc$power, oc$pes_h0, oc$pes_h1),
      Color  = c("#e74c3c","#27ae60","#8e44ad","#3498db")
    )
    p <- ggplot(df, aes(x=Metric, y=Value, fill=Metric)) +
      geom_bar(stat="identity", width=0.6, alpha=0.85) +
      geom_text(aes(label=sprintf("%.3f", Value)), vjust=-0.4, fontface="bold") +
      scale_fill_manual(values=setNames(df$Color, df$Metric)) +
      labs(title="Operating Characteristics", y="Probability") +
      theme_minimal(base_size=12) + theme(legend.position="none") +
      ylim(0, min(1.1, max(df$Value)*1.2))
    ggplotly(p)
  })

  output$oc_sensitivity_plot <- renderPlotly({
    df <- rv$oc_sensitivity
    if (is.null(df)) return(NULL)
    p <- ggplot(df, aes(x=S)) +
      geom_line(aes(y=power, color="Power"),     linewidth=1.4) +
      geom_line(aes(y=t1e,   color="Type I Error"), linewidth=1.2, linetype="dashed") +
      scale_color_manual(values=c("Power"="#27ae60","Type I Error"="#e74c3c")) +
      labs(x="Delay timepoint S (months)", y="Probability", color="",
           title="Sensitivity of Power and Type I Error to S") +
      theme_minimal(base_size=12) + ylim(0,1)
    ggplotly(p)
  })

  # ── ANALYSIS TAB ───────────────────────────────────────────────────────────
  observeEvent(input$run_analysis_btn, {
    tryCatch({
      t0 <- as.numeric(trimws(strsplit(input$t0_an, ",")[[1]]))
      t1 <- as.numeric(trimws(strsplit(input$t1_an, ",")[[1]]))
      d0 <- as.numeric(trimws(strsplit(input$d0_an, ",")[[1]]))
      d1 <- as.numeric(trimws(strsplit(input$d1_an, ",")[[1]]))

      validate(
        need(!any(is.na(t0)), "Invalid control arm times"),
        need(!any(is.na(t1)), "Invalid treatment arm times"),
        need(!any(is.na(d0)), "Invalid control arm events"),
        need(!any(is.na(d1)), "Invalid treatment arm events"),
        need(length(t0)==length(d0), "t0 and δ0 must have same length"),
        need(length(t1)==length(d1), "t1 and δ1 must have same length")
      )

      res <- run_analysis(
        t0=t0, t1=t1, delta0=d0, delta1=d1,
        S_val  = input$S_an,
        n_total = input$N_an,
        lambda  = input$lambda_an, gamma = input$gamma_an,
        a0=input$a0_an, b0=input$b0_an,
        a1=input$a1_an, b1=input$b1_an,
        stage = input$stage_an
      )
      rv$analysis_result  <- res
      rv$analysis_t0 <- t0; rv$analysis_t1 <- t1
      rv$analysis_d0 <- d0; rv$analysis_d1 <- d1

    }, error=function(e) {
      showNotification(paste("Error:", e$message), type="error")
    })
  })

  output$analysis_results_ui <- renderUI({
    res <- rv$analysis_result
    if (is.null(res)) {
      return(p(style="color:#95a5a6; font-style:italic;",
               "Enter data and click 'Run Analysis'."))
    }
    dec_class <- switch(res$decision,
      "Stop for Futility"   = "decision-stop",
      "Continue"            = "decision-continue",
      "Reject H0 (Efficacy)"= "decision-reject",
      "decision-fail"
    )
    tagList(
      fluidRow(
        column(4, div(class="param-well",
          h4(class="result-label", "Posterior P(μ̃₁ < μ̃₀ | Data, S)"),
          h2(style="color:#8e44ad;font-weight:700;", sprintf("%.4f", res$posterior_prob))
        )),
        column(4, div(class="param-well",
          h4(class="result-label", "Adaptive Threshold C(n)"),
          h2(style="color:#e67e22;font-weight:700;", sprintf("%.4f", res$threshold))
        )),
        column(4, div(class="param-well",
          h4(class="result-label", "Stage"),
          h2(style="color:#2c3e50;font-weight:700;", tools::toTitleCase(input$stage_an))
        ))
      ),
      br(),
      div(class=paste("decision-box", dec_class), icon("gavel"), " ", res$decision),
      br(),
      fluidRow(
        column(3, p(strong("n (control):"), res$n_arm)),
        column(3, p(strong("Events (control):"), res$events_control)),
        column(3, p(strong("n (treatment):"), res$n_arm)),
        column(3, p(strong("Events (treatment):"), res$events_treat))
      ),
      conditionalPanel("input.stage_an == 'interim'",
        p(style="font-size:12px; color:#7f8c8d;",
          sprintf("Decision rule: stop if P(μ̃₁ < μ̃₀) = %.4f > C(n) = %.4f → %s",
                  res$posterior_prob, res$threshold,
                  if (res$posterior_prob > res$threshold) "STOP" else "CONTINUE"))
      ),
      conditionalPanel("input.stage_an == 'final'",
        p(style="font-size:12px; color:#7f8c8d;",
          sprintf("Decision rule: reject H₀ if P(μ̃₁ < μ̃₀) = %.4f ≤ C(N) = %.4f → %s",
                  res$posterior_prob, res$threshold,
                  if (res$posterior_prob <= res$threshold) "REJECT" else "FAIL TO REJECT"))
      )
    )
  })

  output$analysis_posterior_plot <- renderPlotly({
    res <- rv$analysis_result
    if (is.null(res)) return(NULL)
    # Show posterior probability relative to threshold
    df <- data.frame(
      x    = c("P(μ̃₁ < μ̃₀ | Data, S)", "Threshold C(n)"),
      y    = c(res$posterior_prob, res$threshold),
      fill = c(if(res$posterior_prob > res$threshold) "#e74c3c" else "#27ae60", "#f39c12")
    )
    p <- ggplot(df, aes(x=x, y=y, fill=fill)) +
      geom_bar(stat="identity", width=0.5, alpha=0.85) +
      geom_text(aes(label=sprintf("%.4f", y)), vjust=-0.4, fontface="bold") +
      scale_fill_identity() +
      labs(title="Posterior Probability vs. Threshold", y="Probability", x="") +
      theme_minimal(base_size=12) + ylim(0, 1.1)
    ggplotly(p)
  })

  output$analysis_km_plot <- renderPlotly({
    t0 <- rv$analysis_t0; t1 <- rv$analysis_t1
    d0 <- rv$analysis_d0; d1 <- rv$analysis_d1
    if (is.null(t0)) return(NULL)

    # Simple KM estimator
    km_df <- function(times, events, group) {
      ord <- order(times)
      times <- times[ord]; events <- events[ord]
      n <- length(times)
      surv <- 1; rows <- list()
      rows[[1]] <- data.frame(time=0, surv=1, group=group)
      for (i in 1:n) {
        if (events[i] == 1) {
          n_at_risk <- n - i + 1
          surv <- surv * (1 - 1/n_at_risk)
        }
        rows[[i+1]] <- data.frame(time=times[i], surv=surv, group=group)
      }
      do.call(rbind, rows)
    }
    df <- rbind(km_df(t0, d0, "Control"), km_df(t1, d1, "Treatment"))
    p <- ggplot(df, aes(x=time, y=surv, color=group)) +
      geom_step(linewidth=1.2) +
      scale_color_manual(values=c("Control"="#e74c3c","Treatment"="#3498db")) +
      labs(x="Time (months)", y="Survival Probability", color="Arm",
           title="Kaplan-Meier Curves") +
      theme_minimal(base_size=12) + ylim(0,1)
    ggplotly(p)
  })
