# Fit truncated Gamma prior for S from expert elicitation
fit_prior_S <- function(L, U, mean_val=NULL, median_val=NULL, sd_val=NULL,
                        q025=NULL, q975=NULL,
                        weights=c(4,4,2,1,1)) {
  # WLS objective: minimise discrepancy between theoretical and elicited summaries
  objective <- function(params) {
    s1 <- exp(params[1]); s2 <- exp(params[2])
    loss <- 0
    if (!is.null(mean_val) && !is.na(mean_val)) {
      th_mean <- tryCatch(mean(truncdist::rtrunc(5000,"gamma",a=L,b=U,shape=s1,scale=s2)),
                          error=function(e) NA)
      if (!is.na(th_mean)) loss <- loss + weights[1]*(th_mean - mean_val)^2
    }
    if (!is.null(median_val) && !is.na(median_val)) {
      th_med <- tryCatch(median(truncdist::rtrunc(5000,"gamma",a=L,b=U,shape=s1,scale=s2)),
                         error=function(e) NA)
      if (!is.na(th_med)) loss <- loss + weights[2]*(th_med - median_val)^2
    }
    if (!is.null(sd_val) && !is.na(sd_val)) {
      th_sd <- tryCatch(sd(truncdist::rtrunc(5000,"gamma",a=L,b=U,shape=s1,scale=s2)),
                        error=function(e) NA)
      if (!is.na(th_sd)) loss <- loss + weights[3]*(th_sd - sd_val)^2
    }
    if (!is.null(q025) && !is.na(q025)) {
      th_q025 <- tryCatch(quantile(truncdist::rtrunc(5000,"gamma",a=L,b=U,shape=s1,scale=s2),0.025),
                          error=function(e) NA)
      if (!is.na(th_q025)) loss <- loss + weights[4]*(th_q025 - q025)^2
    }
    if (!is.null(q975) && !is.na(q975)) {
      th_q975 <- tryCatch(quantile(truncdist::rtrunc(5000,"gamma",a=L,b=U,shape=s1,scale=s2),0.975),
                          error=function(e) NA)
      if (!is.na(th_q975)) loss <- loss + weights[5]*(th_q975 - q975)^2
    }
    if (is.na(loss) || is.infinite(loss)) return(1e10)
    loss
  }
  init <- c(log(2), log((L+U)/4))
  res <- tryCatch(
    optim(init, objective, method="Nelder-Mead",
          control=list(maxit=2000, reltol=1e-8)),
    error=function(e) NULL
  )
  if (is.null(res)) return(list(s1=2, s2=0.5, converged=FALSE))
  list(s1=exp(res$par[1]), s2=exp(res$par[2]), converged=(res$convergence==0))
}

# Convert clinical overall median mu1_bar to model mu1_tilde given S
clinical_to_model_median <- function(mu0_bar, mu1_bar, S) {
  # From equation (8): mu1_bar = (1 - mu1_tilde/mu0_bar)*S + mu1_tilde  if mu0_bar >= S
  # mu1_bar = mu0_bar                                                     if mu0_bar < S
  if (mu0_bar < S) return(mu0_bar)  # no treatment effect before S
  # solve: mu1_bar = S*(1 - mu1t/mu0_bar) + mu1t
  # mu1_bar = S - S*mu1t/mu0_bar + mu1t = S + mu1t*(1 - S/mu0_bar)
  mu1_tilde <- (mu1_bar - S) / (1 - S/mu0_bar)
  pmax(mu1_tilde, 0.001)
}

# Simulate one trial dataset under H0 or H1 (piecewise exponential)
sim_trial_data <- function(n_per_arm, mu0_bar, mu1_bar=NULL, S=NULL,
                           accrual_rate=NULL, null=FALSE) {
  n0 <- n_per_arm; n1 <- n_per_arm
  # Control: Exp(mu0_bar)
  t0 <- rexp(n0, rate=1/mu0_bar)
  if (null) {
    t1 <- rexp(n1, rate=1/mu0_bar)
  } else {
    # Piecewise exponential treatment arm
    mu1_tilde <- clinical_to_model_median(mu0_bar, mu1_bar, S)
    t1 <- numeric(n1)
    for (i in 1:n1) {
      u <- runif(1)
      # CDF of piecewise exp: F(t) = 1 - exp(-t/mu0_bar) for t < S
      #                                1 - exp(-S/mu0_bar - (t-S)/mu1_tilde) for t >= S
      p_before_S <- 1 - exp(-S/mu0_bar)
      if (u < p_before_S) {
        t1[i] <- -mu0_bar * log(1 - u)
      } else {
        u2 <- (u - p_before_S) / (1 - p_before_S)
        t1[i] <- S - mu1_tilde * log(1 - u2)
      }
    }
  }
  list(t0=t0, t1=t1)
}

# Compute P(mu1_tilde < mu0_tilde | data, S) using Lemma 1
compute_posterior_prob <- function(t0, t1, delta0, delta1, S, a0, b0, a1, b1) {
  # Events and TTOT
  d0  <- sum(delta0)
  # For treatment arm: partition at S
  d01 <- sum(delta1[t1 <= S])   # events before S
  d11 <- sum(delta1[t1 >  S])   # events after  S
  TTOT_0_S  <- sum(pmin(t1, S))                       # TTOT(0, S) treatment arm
  TTOT_S_tau <- sum(pmax(0, t1 - S))                  # TTOT(S, tau) treatment arm
  sum_z0    <- sum(t0)

  # Beta parameter (Lemma 1)
  beta_param <- (b0 + TTOT_0_S + sum_z0) /
                (b0 + b1 + sum_z0 + TTOT_0_S + TTOT_S_tau)

  # K ~ Beta(a0 + d0 + d01, a1 + d11)
  alpha_K <- a0 + d0 + d01
  beta_K  <- a1 + d11

  # P(mu1_tilde < mu0_tilde) = P(K < beta_param)
  prob <- pbeta(beta_param, alpha_K, beta_K)
  prob
}

# Adaptive threshold C(n) = 1 - lambda*(n/N)^gamma
threshold_C <- function(n, N, lambda, gamma) {
  1 - lambda * (n/N)^gamma
}

# Single trial simulation for operating characteristics
simulate_one_trial <- function(n_interim, N_total, lambda, gamma,
                               mu0_bar, mu1_bar=NULL, S_val=NULL,
                               a0, b0, a1, b1, null=FALSE) {
  n_per_arm_final <- N_total
  # Generate full dataset
  dat <- sim_trial_data(n_per_arm_final, mu0_bar, mu1_bar, S_val, null=null)
  t0_all <- dat$t0; t1_all <- dat$t1

  # Simulate administrative censoring (everyone followed to max follow-up)
  # We use observed times as event times with event indicator = 1 for simplicity
  delta0 <- rep(1, n_per_arm_final)
  delta1 <- rep(1, n_per_arm_final)

  # Interim analyses
  stopped_early <- FALSE
  for (ni in n_interim) {
    t0 <- t0_all[1:ni]; t1 <- t1_all[1:ni]
    d0 <- delta0[1:ni]; d1 <- delta1[1:ni]
    S_use <- if (!is.null(S_val)) S_val else median(c(t0, t1)) * 0.5

    prob <- compute_posterior_prob(t0, t1, d0, d1, S_use, a0, b0, a1, b1)
    C_n  <- threshold_C(ni, N_total, lambda, gamma)

    if (prob > C_n) {
      stopped_early <- TRUE
      break
    }
  }

  if (stopped_early) return(list(reject=FALSE, stopped_early=TRUE, n_used=ni*2))

  # Final analysis
  t0 <- t0_all; t1 <- t1_all
  d0 <- delta0;  d1 <- delta1
  S_use <- if (!is.null(S_val)) S_val else median(c(t0, t1)) * 0.5
  prob <- compute_posterior_prob(t0, t1, d0, d1, S_use, a0, b0, a1, b1)
  C_N  <- threshold_C(N_total, N_total, lambda, gamma)

  reject <- (prob <= C_N)
  list(reject=reject, stopped_early=FALSE, n_used=N_total*2)
}

# Grid search for optimal (lambda, gamma)
find_optimal_params <- function(N_total, n_interim, mu0_bar, mu1_bar,
                                S_vec, s1, s2, L, U,
                                a0, b0, a1, b1,
                                alpha=0.05, n_sim=2000,
                                lambda_grid=seq(0.1, 0.9, by=0.1),
                                gamma_grid=seq(0.5, 2.0, by=0.25)) {
  results <- list()
  for (lam in lambda_grid) {
    for (gam in gamma_grid) {
      # Type I error: simulate under H0
      rej_h0 <- replicate(n_sim, {
        S_s <- rtrunc(1, "gamma", a=L, b=U, shape=s1, scale=s2)
        r <- simulate_one_trial(n_interim, N_total, lam, gam,
                                mu0_bar, null=TRUE, S_val=S_s,
                                a0=a0, b0=b0, a1=a1, b1=b1)
        as.numeric(r$reject)
      })
      t1e <- mean(rej_h0)
      if (t1e <= alpha) {
        rej_h1 <- replicate(n_sim, {
          S_s <- rtrunc(1, "gamma", a=L, b=U, shape=s1, scale=s2)
          r <- simulate_one_trial(n_interim, N_total, lam, gam,
                                  mu0_bar, mu1_bar=mu1_bar, S_val=S_s, null=FALSE,
                                  a0=a0, b0=b0, a1=a1, b1=b1)
          as.numeric(r$reject)
        })
        pwr <- mean(rej_h1)
        results[[length(results)+1]] <- list(lambda=lam, gamma=gam, t1e=t1e, power=pwr)
      }
    }
  }
  if (length(results)==0) return(NULL)
  df <- do.call(rbind, lapply(results, as.data.frame))
  df[which.max(df$power), ]
}

# Operating characteristics via simulation
compute_oc <- function(N_total, n_interim, lambda, gamma,
                       mu0_bar, mu1_bar, S_fixed=NULL,
                       s1=NULL, s2=NULL, L=NULL, U=NULL,
                       a0, b0, a1, b1, n_sim=2000, use_prior=TRUE) {
  rej_h0 <- numeric(n_sim); es_h0 <- numeric(n_sim); nu_h0 <- numeric(n_sim)
  rej_h1 <- numeric(n_sim); es_h1 <- numeric(n_sim); nu_h1 <- numeric(n_sim)

  for (i in 1:n_sim) {
    S_use <- if (use_prior) rtrunc(1,"gamma",a=L,b=U,shape=s1,scale=s2) else S_fixed

    r0 <- simulate_one_trial(n_interim, N_total, lambda, gamma,
                             mu0_bar, null=TRUE, S_val=S_use,
                             a0=a0, b0=b0, a1=a1, b1=b1)
    rej_h0[i] <- as.numeric(r0$reject)
    es_h0[i]  <- as.numeric(r0$stopped_early)
    nu_h0[i]  <- r0$n_used

    r1 <- simulate_one_trial(n_interim, N_total, lambda, gamma,
                             mu0_bar, mu1_bar=mu1_bar, S_val=S_use, null=FALSE,
                             a0=a0, b0=b0, a1=a1, b1=b1)
    rej_h1[i] <- as.numeric(r1$reject)
    es_h1[i]  <- as.numeric(r1$stopped_early)
    nu_h1[i]  <- r1$n_used
  }

  list(
    type1_error = mean(rej_h0),
    power       = mean(rej_h1),
    pes_h0      = mean(es_h0),
    pes_h1      = mean(es_h1),
    avg_n_h0    = mean(nu_h0),
    avg_n_h1    = mean(nu_h1)
  )
}

# Interim/Final Analysis
run_analysis <- function(t0, t1, delta0, delta1, S_val, n_total,
                         lambda, gamma, a0, b0, a1, b1, stage="final") {
  n_curr <- length(t0)
  prob <- compute_posterior_prob(t0, t1, delta0, delta1, S_val, a0, b0, a1, b1)
  C_n  <- threshold_C(n_curr, n_total, lambda, gamma)

  decision <- if (stage == "interim") {
    if (prob > C_n) "Stop for Futility" else "Continue"
  } else {
    if (prob <= C_n) "Reject H0 (Efficacy)" else "Fail to Reject H0"
  }

  list(
    posterior_prob = prob,
    threshold      = C_n,
    decision       = decision,
    n_arm          = n_curr,
    events_control = sum(delta0),
    events_treat   = sum(delta1)
  )
}

